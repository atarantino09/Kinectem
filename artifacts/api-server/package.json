{
  "name": "@workspace/api-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "prefix-spec": "node prefix-spec.mjs",
    "predev": "node prefix-spec.mjs",
    "dev": "tsx watch src/index.ts",
    "prebuild": "node prefix-spec.mjs",
    "build": "node build.mjs && cp .openapi-prefixed.yaml dist/.openapi-prefixed.yaml",
    "start": "node dist/index.mjs",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.test.json --noEmit"
  },
  "dependencies": {
    "@scalar/api-reference": "^1.52.4",
    "@stoplight/prism-cli": "^5.14.2",
    "@workspace/api-zod": "workspace:*",
    "@workspace/db": "workspace:*",
    "@workspace/scripts": "workspace:*",
    "cookie-parser": "^1.4.7",
    "cors": "^2",
    "drizzle-orm": "catalog:",
    "express": "^5",
    "pino": "^9",
    "pino-http": "^10",
    "yaml": "^2.8.3",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "catalog:",
    "@types/pg": "^8.18.0",
    "@types/supertest": "^7.2.0",
    "esbuild": "^0.27.3",
    "esbuild-plugin-pino": "^2.3.3",
    "pg": "^8.20.0",
    "pino-pretty": "^13",
    "supertest": "^7.2.2",
    "thread-stream": "3.1.0",
    "tsx": "^4.21.0",
    "vitest": "^4.1.5"
  }
}
