{
  "name": "@kinectem/sdk",
  "version": "0.1.0",
  "description": "TypeScript client SDK for the Kinectem API. React Native / Expo / Node / browser compatible.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./openapi.json": "./openapi.json"
  },
  "files": [
    "dist",
    "openapi.json",
    "README.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.json",
    "prepack": "npm run build"
  },
  "keywords": [
    "kinectem",
    "api",
    "sdk",
    "react-native",
    "expo"
  ],
  "license": "UNLICENSED",
  "devDependencies": {
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=18"
  }
}
